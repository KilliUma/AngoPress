# Verificar que a mensagem de commit segue o padrão Conventional Commits
# Padrão: type(scope): description
# Exemplos: feat(auth): add JWT refresh token
#           fix(campaigns): correct send quota validation
#           chore: update dependencies

commit_msg_file=$1
commit_msg=$(cat "$commit_msg_file")

pattern="^(feat|fix|chore|docs|style|refactor|test|perf|ci|build|revert)(\(.+\))?: .{1,100}$"

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo ""
  echo "❌ Mensagem de commit inválida!"
  echo ""
  echo "Formato esperado: type(scope): description"
  echo ""
  echo "Tipos permitidos:"
  echo "  feat     - Nova funcionalidade"
  echo "  fix      - Correção de bug"
  echo "  chore    - Tarefas de manutenção"
  echo "  docs     - Documentação"
  echo "  style    - Formatação, sem mudança de lógica"
  echo "  refactor - Refatoração de código"
  echo "  test     - Testes"
  echo "  perf     - Otimização de performance"
  echo "  ci       - CI/CD"
  echo "  build    - Build"
  echo "  revert   - Reverter commit"
  echo ""
  echo "Exemplos:"
  echo "  feat(auth): add JWT refresh token rotation"
  echo "  fix(campaigns): correct send quota validation"
  echo ""
  exit 1
fi
