# ─────────────────────────────────────────────────────────
# AngoPress — Variáveis de Ambiente
# Copiar para .env e preencher com os valores reais
# NUNCA commitar o ficheiro .env
# ─────────────────────────────────────────────────────────

# ─── API ────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
CLIENT_URL=http://localhost:5173

# ─── Banco de Dados ─────────────────────────────────────
DATABASE_URL=postgresql://angopress:angopress_dev@localhost:5434/angopress

# ─── Docker (para docker-compose) ───────────────────────
POSTGRES_USER=angopress
POSTGRES_PASSWORD=angopress_dev
POSTGRES_DB=angopress

# ─── Redis ──────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev
REDIS_TLS=false

# ─── JWT ─────────────────────────────────────────────────
# Gerar com: openssl rand -hex 64
JWT_SECRET=SUBSTITUIR_COM_SECRET_SEGURO_MINIMO_64_CHARS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=SUBSTITUIR_COM_REFRESH_SECRET_SEGURO_MINIMO_64_CHARS
JWT_REFRESH_EXPIRES_IN=7d

# ─── AWS ─────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=SUBSTITUIR
AWS_SECRET_ACCESS_KEY=SUBSTITUIR

# Amazon SES (legado — substituído pelo Resend)
AWS_SES_FROM_EMAIL=noreply@angopress.ao
AWS_SES_FROM_NAME=AngoPress
AWS_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:CONTA:angopress-ses-events

# Amazon S3
AWS_S3_BUCKET=angopress-uploads
AWS_S3_BASE_URL=https://angopress-uploads.s3.amazonaws.com

# ─── Resend (envio de email) ──────────────────────────────
# Obter em: https://resend.com/api-keys
# NUNCA commitar a chave real — usar .env.local (ignorado pelo git)
RESEND_API_KEY=re_SUBSTITUIR_COM_API_KEY
# Em produção, usar domínio verificado na Resend.
RESEND_FROM_EMAIL=noreply@angopress.ao
RESEND_FROM_NAME=AngoPress

# ─── Frontend (web — React/Vite) ─────────────────────────
VITE_API_URL=http://localhost:3001
VITE_SENTRY_DSN=
VITE_APP_VERSION=1.0.0

# ─── Landing (Next.js) ───────────────────────────────────
# API_URL já definida acima
# APP_URL aponta para o domínio público do sistema.
APP_URL=https://sistema.angopress.ao
NEXT_PUBLIC_APP_URL=https://sistema.angopress.ao

# ─── CORS (API) ──────────────────────────────────────────
# URLs dos frontends permitidas pelo CORS
LANDING_URL=https://angopress.ao

# ─────────────────────────────────────────────────────────
# PRODUÇÃO — Vercel + Railway + Neon + Upstash
# ─────────────────────────────────────────────────────────
#
# API (Railway):
#   NODE_ENV=production
#   PORT=3001
#   DATABASE_URL=postgres://user:pass@neon.tech/angopress?sslmode=require
#   REDIS_URL=rediss://user:pass@upstash.io:PORT
#   REDIS_TLS=true
#   CLIENT_URL=https://sistema.angopress.ao
#   LANDING_URL=https://angopress.ao
#   JWT_SECRET=<openssl rand -hex 64>
#   JWT_REFRESH_SECRET=<openssl rand -hex 64>
#   AWS_REGION / AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / ...
#   RESEND_API_KEY=re_xxxxx
#   RESEND_FROM_EMAIL=noreply@angopress.ao
#   RESEND_FROM_NAME=AngoPress
#
# Web (Vercel — projeto "angopress-web"):
#   VITE_API_URL=https://api.angopress.ao
#   NEXT_PUBLIC_APP_URL=https://sistema.angopress.ao
#
# Landing (Vercel — projeto "angopress-landing"):
#   API_URL=https://api.angopress.ao
#   APP_URL=https://sistema.angopress.ao
#   NEXT_PUBLIC_SITE_URL=https://angopress.ao
